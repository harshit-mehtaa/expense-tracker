# =============================================================================
# Family Finance Tracker — Environment Variables
# Copy this file to .env and fill in the values before running docker compose
# =============================================================================

# --- PostgreSQL ---
POSTGRES_DB=familyfinance
POSTGRES_USER=familyfinance
POSTGRES_PASSWORD=changeme_strong_password

# Prisma uses this to connect (constructed from above; keep in sync)
DATABASE_URL=postgresql://familyfinance:changeme_strong_password@db:5432/familyfinance

# --- JWT ---
# Generate with: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET=changeme_generate_a_64_byte_hex_secret
JWT_REFRESH_SECRET=changeme_generate_a_different_64_byte_hex_secret

# --- App ---
NODE_ENV=development
PORT=3000

# Frontend URL (used for CORS and cookie domain)
FRONTEND_URL=http://localhost
COOKIE_DOMAIN=localhost

# --- Vite (frontend) ---
# In Docker Compose, frontend talks to nginx which proxies to backend
VITE_API_URL=http://localhost/api
